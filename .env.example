# Google Gemini API key for AI-powered coaching (optional — expert system works without it)
# Get free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Hugging Face API key for FinBERT sentiment analysis (optional — falls back to keyword heuristics)
HF_API_TOKEN=hf_...

# Public app URL for SEO meta tags and sitemap (set to your deployment URL)
NEXT_PUBLIC_APP_URL=https://tradia.vercel.app

# Sentry error monitoring (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Database URL — PostgreSQL (NeonDB) or local SQLite
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# GitHub OAuth (optional — for GitHub login)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend email service (optional — falls back to console.log in development)
# Get free at: https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Tradia <noreply@yourdomain.com>
